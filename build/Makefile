	$(MAKE) $(MAKESILENT) -f CMakeFiles/mission.dir/build.make CMakeFiles/mission.dir/src/tsp_search.cpp.s
	$(MAKE) $(MAKESILENT) -f CMakeFiles/testTSP.dir/build.make CMakeFiles/testTSP.dir/src/tsp_search.cpp.s
.PHONY : src/tsp_search.cpp.s

